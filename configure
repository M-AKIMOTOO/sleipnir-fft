#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PREFIX="/usr/local"
ODIN="${ODIN:-$(command -v odin 2>/dev/null || true)}"
BUILD_DIR="$ROOT_DIR/build"
LIB_MODE="static"
LIB_NAME="sleipnir_fft"
ODIN_OPT="speed"
MICROARCH="native"
PKG_NAME="sleipnir-fft"

usage() {
  cat <<'EOF'
Usage: ./configure [options]

Options:
  --prefix=PATH         Install prefix (default: /usr/local)
  --odin=PATH           Odin compiler path (default: from PATH)
  --build-dir=PATH      Build directory (default: ./build)
  --mode=MODE           Library mode: static/shared/lib/dll (default: static)
  --lib-name=NAME       Output library base name without prefix/suffix (default: sleipnir_fft)
  --opt=LEVEL           Odin optimization level or "none" (default: speed)
  --microarch=TARGET    Microarchitecture target or "none" (default: native)
  --pkg-name=NAME       Installed package directory name (default: sleipnir-fft)
  -h, --help            Show this help

Example:
  ./configure --prefix=$HOME/.local --mode=static --microarch=native
EOF
}

require_no_whitespace() {
  local label="$1"
  local value="$2"
  if [[ "$value" =~ [[:space:]] ]]; then
    echo "error: $label cannot contain whitespace: '$value'" >&2
    exit 1
  fi
}

for arg in "$@"; do
  case "$arg" in
    --prefix=*) PREFIX="${arg#*=}" ;;
    --odin=*) ODIN="${arg#*=}" ;;
    --build-dir=*) BUILD_DIR="${arg#*=}" ;;
    --mode=*) LIB_MODE="${arg#*=}" ;;
    --lib-mode=*) LIB_MODE="${arg#*=}" ;;
    --lib-name=*) LIB_NAME="${arg#*=}" ;;
    --name=*) LIB_NAME="${arg#*=}" ;;
    --opt=*) ODIN_OPT="${arg#*=}" ;;
    --microarch=*) MICROARCH="${arg#*=}" ;;
    --pkg-name=*) PKG_NAME="${arg#*=}" ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown option '$arg'" >&2
      usage
      exit 1
      ;;
  esac
done

case "$LIB_MODE" in
  static|shared|lib|dll) ;;
  *)
    echo "error: --mode must be one of: static, shared, lib, dll" >&2
    exit 1
    ;;
esac

require_no_whitespace "prefix" "$PREFIX"
require_no_whitespace "build-dir" "$BUILD_DIR"
require_no_whitespace "lib-name" "$LIB_NAME"
require_no_whitespace "opt" "$ODIN_OPT"
require_no_whitespace "microarch" "$MICROARCH"
require_no_whitespace "pkg-name" "$PKG_NAME"

resolve_odin() {
  local odin_bin="$1"
  local resolved=""
  if [[ -z "$odin_bin" ]]; then
    echo "error: Odin compiler not found in PATH. Use --odin=PATH" >&2
    exit 1
  fi
  if [[ "$odin_bin" == */* ]]; then
    if [[ ! -x "$odin_bin" ]]; then
      echo "error: Odin compiler is not executable: $odin_bin" >&2
      exit 1
    fi
    resolved="$odin_bin"
  else
    resolved="$(command -v "$odin_bin" 2>/dev/null || true)"
    if [[ -z "$resolved" ]]; then
      echo "error: Odin compiler '$odin_bin' was not found in PATH" >&2
      exit 1
    fi
  fi
  printf '%s\n' "$resolved"
}

ODIN="$(resolve_odin "$ODIN")"

mkdir -p "$BUILD_DIR"
CONFIG_MK="$BUILD_DIR/config.mk"

cat > "$CONFIG_MK" <<EOF
# Auto-generated by ./configure on $(date -u +"%Y-%m-%dT%H:%M:%SZ")
PREFIX := $PREFIX
ODIN := $ODIN
BUILD_DIR := $BUILD_DIR
LIB_MODE := $LIB_MODE
LIB_NAME := $LIB_NAME
ODIN_OPT := $ODIN_OPT
MICROARCH := $MICROARCH
PKG_NAME := $PKG_NAME
INSTALL_PKG_ROOT := $PREFIX/share/$PKG_NAME
INSTALL_LIB_DIR := $PREFIX/lib
EOF

echo "Configuration written to: $CONFIG_MK"
echo "  PREFIX=$PREFIX"
echo "  ODIN=$ODIN"
echo "  LIB_MODE=$LIB_MODE"
echo "  LIB_NAME=$LIB_NAME"
echo "  ODIN_OPT=$ODIN_OPT"
echo "  MICROARCH=$MICROARCH"
echo "  PKG_NAME=$PKG_NAME"
echo
echo "Next:"
echo "  make -j"
echo "  make install"
